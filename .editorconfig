root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4
max_line_length = 120

[*.xml]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{md,json,js,jsx,ts,tsx,css,scss,html}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{bat,cmd}]
end_of_line = crlf